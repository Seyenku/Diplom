@page
@model KosmosCore.Pages.TestModel
@{
    ViewData["Title"] = "Профориентационный тест";
}

<div class="test-wizard-container">
    <div class="wizard-card">
        <div class="wizard-header">
            <h2 class="wizard-title">Матрица выбора профессии</h2>
            <p class="wizard-subtitle">Методика Г.В. Резапкиной</p>
        </div>

        <div class="wizard-progress">
            <div class="progress-dot active" id="dot-1"></div>
            <div class="progress-dot" id="dot-2"></div>
            <div class="progress-dot" id="dot-3"></div>
        </div>

        <!-- Step 1: Объект деятельности -->
        <div id="step-1" class="wizard-step">
            <h3 style="font-weight: 700; margin-bottom: 24px; text-align: center;">Шаг 1. Какой объект деятельности Вас привлекает?</h3>
            <p style="text-align: center; color: var(--color-text-muted); margin-bottom: 30px;">Выберите один или два варианта из списка ниже.</p>
            
            <div class="options-grid" id="options-1">
                <button class="option-btn" data-value="человек">
                    <span class="option-title">👩‍🏫 Человек</span>
                    <span class="option-desc">Дети и взрослые, ученики и студенты, клиенты и пациенты, зрители.</span>
                </button>
                <button class="option-btn" data-value="информация">
                    <span class="option-title">💻 Информация</span>
                    <span class="option-desc">Тексты, формулы, схемы, коды, чертежи, языки программирования.</span>
                </button>
                <button class="option-btn" data-value="финансы">
                    <span class="option-title">📈 Финансы</span>
                    <span class="option-desc">Деньги, акции, фонды, лимиты, кредиты.</span>
                </button>
                <button class="option-btn" data-value="техника">
                    <span class="option-title">⚙️ Техника</span>
                    <span class="option-desc">Механизмы, станки, здания, конструкции, приборы и машины.</span>
                </button>
                <button class="option-btn" data-value="искусство">
                    <span class="option-title">🎨 Искусство</span>
                    <span class="option-desc">Литература, музыка, театр, кино, балет, живопись.</span>
                </button>
                <button class="option-btn" data-value="животные">
                    <span class="option-title">🐾 Животные</span>
                    <span class="option-desc">Служебные, дикие, домашние, промысловые.</span>
                </button>
                <button class="option-btn" data-value="растения">
                    <span class="option-title">🌱 Растения</span>
                    <span class="option-desc">Сельскохозяйственные, дикорастущие, декоративные.</span>
                </button>
                <button class="option-btn" data-value="продукты">
                    <span class="option-title">🍱 Продукты питания</span>
                    <span class="option-desc">Мясные, рыбные, молочные, кондитерские изделия.</span>
                </button>
                <button class="option-btn" data-value="изделия">
                    <span class="option-title">🧵 Изделия</span>
                    <span class="option-desc">Металл, ткани, мех, кожа, дерево, камень.</span>
                </button>
                <button class="option-btn" data-value="природа">
                    <span class="option-title">🌲 Природные ресурсы</span>
                    <span class="option-desc">Земли, леса, горы, водоёмы, месторождения.</span>
                </button>
            </div>
        </div>

        <!-- Step 2: Вид деятельности -->
        <div id="step-2" class="wizard-step" style="display: none;">
            <h3 style="font-weight: 700; margin-bottom: 24px; text-align: center;">Шаг 2. Какой вид деятельности наиболее Вам интересен?</h3>
            <p style="text-align: center; color: var(--color-text-muted); margin-bottom: 30px;">Выберите один подходящий вариант.</p>
            
            <div class="options-grid" id="options-2">
                <button class="option-btn" data-value="управление">
                    <span class="option-title">📊 Управление</span>
                    <span class="option-desc">Руководство чьей-то деятельностью.</span>
                </button>
                <button class="option-btn" data-value="обслуживание">
                    <span class="option-title">🤝 Обслуживание</span>
                    <span class="option-desc">Помощь людям, удовлетворение их потребностей.</span>
                </button>
                <button class="option-btn" data-value="образование">
                    <span class="option-title">📚 Образование</span>
                    <span class="option-desc">Воспитание, обучение, формирование личности.</span>
                </button>
                <button class="option-btn" data-value="оздоровление">
                    <span class="option-title">⚕️ Оздоровление</span>
                    <span class="option-desc">Избавление от болезней и их предупреждение.</span>
                </button>
                <button class="option-btn" data-value="творчество">
                    <span class="option-title">💡 Творчество</span>
                    <span class="option-desc">Создание оригинальных произведений искусства.</span>
                </button>
                <button class="option-btn" data-value="производство">
                    <span class="option-title">🏭 Производство</span>
                    <span class="option-desc">Изготовление продукции.</span>
                </button>
                <button class="option-btn" data-value="конструирование">
                    <span class="option-title">📐 Конструирование</span>
                    <span class="option-desc">Проектирование деталей.</span>
                </button>
                <button class="option-btn" data-value="исследование">
                    <span class="option-title">🔬 Исследование</span>
                    <span class="option-desc">Научное изучение чего-либо или кого-либо.</span>
                </button>
                <button class="option-btn" data-value="защита">
                    <span class="option-title">🛡️ Защита</span>
                    <span class="option-desc">Охрана от враждебных действий.</span>
                </button>
                <button class="option-btn" data-value="контроль">
                    <span class="option-title">✅ Контроль</span>
                    <span class="option-desc">Проверка и наблюдение.</span>
                </button>
            </div>
        </div>

        <!-- Step 3: Result -->
        <div id="step-3" class="wizard-step" style="display: none;">
            <div class="result-box">
                <h3 style="font-weight: 700; margin-bottom: 16px; color: var(--color-accent);">Ваш результат</h3>
                <p style="color: var(--color-text-muted);">На основе вашего выбора наиболее подходящие профессии будущего:</p>
                <div class="result-professions" id="result-container">
                    <!-- Заполняется через JS -->
                </div>
                
                <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid rgba(0,0,0,0.1);">
                    <p style="margin-bottom: 20px;">Готовы исследовать образовательную галактику?</p>
                    <a href="~/proj" class="btn-wizard btn-next" style="text-decoration: none; display: inline-block;">Перейти в Атлас</a>
                </div>
            </div>
        </div>

        <div class="wizard-footer" id="wizard-controls">
            <button class="btn-wizard btn-prev" id="btn-back" style="visibility: hidden;">Назад</button>
            <button class="btn-wizard btn-next" id="btn-next" disabled>Далее</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/testWizard.js" asp-append-version="true"></script>
}
