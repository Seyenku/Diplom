@page
@model KosmosCore.Pages.LoginModel
@{
    ViewData["Title"] = "Вход";
}

@section Head {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h1 class="auth-card__title">Вход в систему</h1>
        <p class="auth-card__subtitle">Атлас профессий будущего</p>

        <div asp-validation-summary="ModelOnly"></div>

        <form method="post">
            <div class="auth-field">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" placeholder="Введите логин" autocomplete="username" />
                <span asp-validation-for="UserName"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" placeholder="Введите пароль" autocomplete="current-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="auth-btn">Войти</button>
        </form>


    </div>
</div>
