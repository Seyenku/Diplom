@page
@model KosmosCore.Pages.SpecModel
@{
    ViewData["Title"] = "Направления подготовки";
}

<div class="spec-page" data-spec-page>
    <div class="spec-header">
        <h1 class="spec-title">Направления подготовки</h1>
        <p class="spec-subtitle">Перечень образовательных программ СГУ им. Питирима Сорокина, связанных с профессиями будущего</p>
    </div>

    @if (Model.Directions.Count == 0)
    {
        <div class="spec-empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14,2 14,8 20,8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10,9 9,9 8,9"/>
            </svg>
            <p>Данные о направлениях пока не добавлены.</p>
        </div>
    }
    else
    {
        <section class="spec-toolbar" aria-label="Поиск направлений">
            <div class="spec-search">
                <svg class="spec-search__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
                <input id="spec-search"
                       class="spec-search__input"
                       type="search"
                       placeholder="Поиск по названию, коду, экзаменам, профессиям"
                       autocomplete="off"
                       aria-label="Поиск по направлениям подготовки" />
                <button id="spec-search-clear" class="spec-search__clear" type="button" aria-label="Очистить поиск" hidden>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M18 6 6 18"></path>
                        <path d="m6 6 12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="spec-toolbar__meta">
                <span id="spec-result-count" class="spec-result-count"></span>
            </div>
        </section>

        <div id="spec-no-results" class="spec-empty spec-empty--compact" hidden>
            <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
                <path d="M8 11h6"></path>
            </svg>
            <p>Ничего не найдено. Попробуйте другой запрос.</p>
        </div>

        <div class="spec-browser">
            <aside class="spec-result-panel" aria-label="Найденные направления">
                <div class="spec-result-panel__header">
                    <span>Найденные направления</span>
                </div>
                <div id="spec-result-list" class="spec-result-list" role="listbox" aria-label="Список направлений"></div>
            </aside>

            <section class="spec-detail-panel" aria-label="Подробная информация о направлении">
                <div class="spec-grid">
                    @foreach (var dir in Model.Directions)
                    {
                        var searchCorpus = string.Join(" ", new[]
                        {
                            dir.Code,
                            dir.Title,
                            dir.EduForm,
                            dir.Description,
                            dir.Disciplines,
                            dir.Exams,
                            dir.Spheres,
                            dir.Professions
                        }.Where(value => !string.IsNullOrWhiteSpace(value)));
                        var admissionHistory = dir.AdmissionHistory.OrderBy(stat => stat.Year).ToList();
                        var passingChartLabels = System.Text.Json.JsonSerializer.Serialize(admissionHistory.Select(stat => stat.Year.ToString()).ToArray());
                        var passingChartValues = System.Text.Json.JsonSerializer.Serialize(admissionHistory.Select(stat => stat.MinPassingScore).ToArray());

                        <article class="spec-card"
                                 id="spec-card-@dir.ProgramId"
                                 data-spec-card
                                 data-search="@searchCorpus"
                                 data-code="@dir.Code"
                                 data-title="@dir.Title"
                                 data-edu-form="@dir.EduForm"
                                 data-years="@dir.YearsEduc">
                            <div class="spec-card__header">
                                <span class="spec-card__code">@dir.Code</span>
                                <h2 class="spec-card__title">@dir.Title</h2>
                            </div>

                            <div class="spec-card__body">
                                <div class="spec-card__meta">
                                    <div class="spec-meta-item">
                                        <span class="spec-meta-label">Форма обучения</span>
                                        <span class="spec-meta-value">@dir.EduForm</span>
                                    </div>
                                    <div class="spec-meta-item">
                                        <span class="spec-meta-label">Срок обучения</span>
                                        <span class="spec-meta-value">@dir.YearsEduc г.</span>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(dir.Description))
                                {
                                    <div class="spec-card__section">
                                        <h3 class="spec-section-title">Описание</h3>
                                        <p class="spec-section-text">@dir.Description</p>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(dir.Disciplines))
                                {
                                    <div class="spec-card__section">
                                        <h3 class="spec-section-title">Читаемые дисциплины</h3>
                                        <p class="spec-section-text">@dir.Disciplines</p>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(dir.Exams))
                                {
                                    <div class="spec-card__section">
                                        <h3 class="spec-section-title">Вступительные испытания</h3>
                                        <div class="spec-tags">
                                            @foreach (var exam in dir.Exams.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="spec-tag spec-tag--exam">@exam</span>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(dir.Spheres))
                                {
                                    <div class="spec-card__section">
                                        <h3 class="spec-section-title">Сферы трудоустройства</h3>
                                        <p class="spec-section-text">@dir.Spheres</p>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(dir.Professions))
                                {
                                    <div class="spec-card__section">
                                        <h3 class="spec-section-title">Профессии будущего</h3>
                                        <div class="spec-tags">
                                            @foreach (var prof in dir.Professions.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="spec-tag spec-tag--profession">@prof</span>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (admissionHistory.Count > 0)
                                {
                                    <details class="spec-card__details">
                                        <summary class="spec-details-toggle">
                                            <span>Статистика приёма</span>
                                            <svg class="spec-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="6,9 12,15 18,9"/>
                                            </svg>
                                        </summary>
                                        <div class="spec-details-content">
                                            <div class="spec-stats-chart" aria-label="График проходного балла по годам">
                                                <div class="spec-stats-chart__header">
                                                    <div>
                                                        <span class="spec-stats-chart__eyebrow">Динамика проходного балла</span>
                                                        <h4 class="spec-stats-chart__title">Проходной балл по годам</h4>
                                                    </div>
                                                    <span class="spec-stats-chart__badge">Проходной балл</span>
                                                </div>

                                                <div class="spec-line-chart" role="img" aria-label="Линейный график проходного балла по годам">
                                                    <canvas class="spec-score-chart"
                                                            data-chart-labels="@passingChartLabels"
                                                            data-chart-values="@passingChartValues"></canvas>
                                                </div>
                                            </div>

                                            <div class="spec-stats-table-wrap">
                                                <table class="spec-stats-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Год</th>
                                                            <th>Стоимость</th>
                                                            <th>Бюджетные места</th>
                                                            <th>Проходной балл</th>
                                                            <th>Средний балл ЕГЭ</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var stat in admissionHistory.OrderByDescending(stat => stat.Year))
                                                        {
                                                            <tr>
                                                                <td>@stat.Year</td>
                                                                <td>@stat.Price.ToString("N0") ₽</td>
                                                                <td>@stat.BudgetPlaces</td>
                                                                <td>@stat.MinPassingScore</td>
                                                                <td>@(stat.AvgEgeScore.HasValue ? stat.AvgEgeScore.Value.ToString("F1") : "—")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </details>
                                }
                            </div>
                        </article>
                    }
                </div>

                <nav id="spec-pagination" class="spec-pagination" aria-label="Переключение выбранного направления">
                    <button id="spec-page-prev" class="spec-page-btn" type="button" aria-label="Предыдущее направление">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m15 18-6-6 6-6"></path>
                        </svg>
                    </button>
                    <div id="spec-page-status" class="spec-page-status" aria-live="polite"></div>
                    <button id="spec-page-next" class="spec-page-btn" type="button" aria-label="Следующее направление">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m9 18 6-6-6-6"></path>
                        </svg>
                    </button>
                </nav>
            </section>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
    <script>
        (() => {
            const cards = Array.from(document.querySelectorAll('[data-spec-card]'));
            const searchInput = document.getElementById('spec-search');
            const clearButton = document.getElementById('spec-search-clear');
            const resultCount = document.getElementById('spec-result-count');
            const resultList = document.getElementById('spec-result-list');
            const pagination = document.getElementById('spec-pagination');
            const pageStatus = document.getElementById('spec-page-status');
            const prevButton = document.getElementById('spec-page-prev');
            const nextButton = document.getElementById('spec-page-next');
            const noResults = document.getElementById('spec-no-results');
            const detailPanel = document.querySelector('.spec-detail-panel');
            const charts = new Set();

            if (!searchInput || !resultList || !pagination || !pageStatus || !prevButton || !nextButton) return;

            let currentIndex = 0;
            let currentQuery = '';

            const getCssValue = name => getComputedStyle(document.documentElement).getPropertyValue(name).trim();

            function getChartColors() {
                const isDark = document.documentElement.dataset.theme === 'dark';

                return {
                    line: getCssValue('--color-accent-mint') || '#059669',
                    text: getCssValue('--color-text-primary') || '#1e293b',
                    muted: getCssValue('--color-text-muted') || '#64748b',
                    pointBorder: isDark ? '#0f172a' : '#ffffff',
                    grid: isDark ? 'rgba(148, 163, 184, 0.16)' : 'rgba(100, 116, 139, 0.16)',
                    fillStart: isDark ? 'rgba(94, 234, 212, 0.22)' : 'rgba(16, 185, 129, 0.22)',
                    fillEnd: isDark ? 'rgba(94, 234, 212, 0.02)' : 'rgba(16, 185, 129, 0.02)',
                    tooltipBg: isDark ? 'rgba(15, 23, 42, 0.96)' : '#ffffff',
                    tooltipBorder: isDark ? 'rgba(94, 234, 212, 0.24)' : 'rgba(5, 150, 105, 0.20)',
                    tooltipBody: isDark ? '#5eead4' : '#047857'
                };
            }

            function createChartGradient(context, colors) {
                const chart = context.chart;
                const area = chart.chartArea;
                if (!area) return colors.fillStart;

                const gradient = chart.ctx.createLinearGradient(0, area.top, 0, area.bottom);
                gradient.addColorStop(0, colors.fillStart);
                gradient.addColorStop(1, colors.fillEnd);
                return gradient;
            }

            function applyChartTheme(chart) {
                const colors = getChartColors();
                const dataset = chart.data.datasets[0];

                dataset.borderColor = colors.line;
                dataset.pointBackgroundColor = colors.line;
                dataset.pointBorderColor = colors.pointBorder;
                dataset.backgroundColor = context => createChartGradient(context, colors);

                chart.options.scales.x.ticks.color = colors.muted;
                chart.options.scales.y.ticks.color = colors.muted;
                chart.options.scales.y.grid.color = colors.grid;
                chart.options.plugins.tooltip.backgroundColor = colors.tooltipBg;
                chart.options.plugins.tooltip.borderColor = colors.tooltipBorder;
                chart.options.plugins.tooltip.titleColor = colors.text;
                chart.options.plugins.tooltip.bodyColor = colors.tooltipBody;

                chart.update('none');
            }

            const normalize = value => (value || '').toLocaleLowerCase('ru-RU').replaceAll('ё', 'е').trim();

            function initCharts(scope = document) {
                if (!window.Chart) return;

                scope.querySelectorAll('.spec-score-chart:not([data-chart-ready])').forEach(canvas => {
                    const labels = JSON.parse(canvas.dataset.chartLabels || '[]');
                    const values = JSON.parse(canvas.dataset.chartValues || '[]').map(Number);
                    if (!labels.length || !values.length) return;

                    const minValue = Math.min(...values);
                    const maxValue = Math.max(...values);
                    const padding = Math.max(5, Math.ceil((maxValue - minValue || 10) * 0.2));
                    const yMin = Math.max(0, Math.floor((minValue - padding) / 10) * 10);
                    const yMax = Math.ceil((maxValue + padding) / 10) * 10;
                    const colors = getChartColors();

                    canvas.dataset.chartReady = 'true';
                    const chart = new Chart(canvas, {
                        type: 'line',
                        data: {
                            labels,
                            datasets: [{
                                label: 'Проходной балл',
                                data: values,
                                borderColor: colors.line,
                                backgroundColor: context => createChartGradient(context, colors),
                                borderWidth: 3,
                                pointRadius: 5,
                                pointHoverRadius: 7,
                                pointBackgroundColor: colors.line,
                                pointBorderColor: colors.pointBorder,
                                pointBorderWidth: 3,
                                pointHoverBorderWidth: 3,
                                tension: 0.36,
                                fill: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                intersect: false,
                                mode: 'index'
                            },
                            scales: {
                                x: {
                                    grid: {
                                        display: false
                                    },
                                    border: {
                                        display: false
                                    },
                                    ticks: {
                                        color: colors.muted,
                                        font: {
                                            family: "'Roboto Slab', serif",
                                            size: 12,
                                            weight: 800
                                        }
                                    }
                                },
                                y: {
                                    min: yMin,
                                    max: yMax,
                                    border: {
                                        display: false
                                    },
                                    grid: {
                                        color: colors.grid,
                                        drawTicks: false
                                    },
                                    ticks: {
                                        color: colors.muted,
                                        padding: 10,
                                        precision: 0,
                                        stepSize: 10,
                                        font: {
                                            family: "'Roboto Slab', serif",
                                            size: 12,
                                            weight: 700
                                        }
                                    }
                                }
                            },
                            plugins: {
                                legend: {
                                    display: false
                                },
                                tooltip: {
                                    displayColors: false,
                                    backgroundColor: colors.tooltipBg,
                                    borderColor: colors.tooltipBorder,
                                    borderWidth: 1,
                                    titleColor: colors.text,
                                    bodyColor: colors.tooltipBody,
                                    titleFont: {
                                        family: "'Roboto Slab', serif",
                                        weight: 800
                                    },
                                    bodyFont: {
                                        family: "'Roboto Slab', serif",
                                        weight: 800
                                    },
                                    padding: 12,
                                    callbacks: {
                                        label: context => `Проходной балл: ${context.parsed.y}`
                                    }
                                }
                            }
                        }
                    });

                    charts.add(chart);
                });
            }

            window.addEventListener('kosmos:themechange', () => {
                charts.forEach(applyChartTheme);
            });

            document.querySelectorAll('.spec-card__details').forEach(details => {
                const summary = details.querySelector('.spec-details-toggle');
                const content = details.querySelector('.spec-details-content');
                if (!summary || !content) return;

                summary.addEventListener('click', event => {
                    event.preventDefault();
                    if (details.dataset.animating === 'true') return;

                    if (details.open) {
                        closeDetails(details, content);
                    } else {
                        openDetails(details, content);
                    }
                });
            });

            function openDetails(details, content) {
                details.dataset.animating = 'true';
                content.style.maxHeight = '0px';
                content.style.opacity = '0';
                content.style.overflow = 'hidden';
                details.open = true;
                requestAnimationFrame(() => initCharts(details));

                const targetHeight = content.scrollHeight;
                const animation = content.animate([
                    { maxHeight: '0px', opacity: 0, transform: 'translateY(-8px)' },
                    { maxHeight: `${targetHeight}px`, opacity: 1, transform: 'translateY(0)' }
                ], {
                    duration: 300,
                    easing: 'cubic-bezier(0.22, 1, 0.36, 1)'
                });

                animation.onfinish = () => {
                    content.style.maxHeight = '';
                    content.style.opacity = '';
                    content.style.overflow = '';
                    details.dataset.animating = 'false';
                };
            }

            function closeDetails(details, content) {
                details.dataset.animating = 'true';
                content.style.overflow = 'hidden';

                const startHeight = content.scrollHeight;
                const animation = content.animate([
                    { maxHeight: `${startHeight}px`, opacity: 1, transform: 'translateY(0)' },
                    { maxHeight: '0px', opacity: 0, transform: 'translateY(-8px)' }
                ], {
                    duration: 240,
                    easing: 'ease'
                });

                animation.onfinish = () => {
                    details.open = false;
                    content.style.maxHeight = '';
                    content.style.opacity = '';
                    content.style.overflow = '';
                    details.dataset.animating = 'false';
                };
            }

            function getFilteredCards() {
                const query = normalize(currentQuery);
                if (!query) return cards;
                return cards.filter(card => normalize(card.dataset.search || card.textContent).includes(query));
            }

            function setCardVisible(card, visible) {
                card.hidden = !visible;
                card.classList.toggle('spec-card--hidden', !visible);
            }

            function buildResultList(filtered) {
                resultList.innerHTML = '';

                filtered.forEach((card, index) => {
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'spec-result-item';
                    button.setAttribute('role', 'option');
                    button.setAttribute('aria-selected', index === currentIndex ? 'true' : 'false');

                    const code = document.createElement('span');
                    code.className = 'spec-result-item__code';
                    code.textContent = card.dataset.code || '';

                    const title = document.createElement('span');
                    title.className = 'spec-result-item__title';
                    title.textContent = card.dataset.title || '';

                    button.append(code, title);
                    button.addEventListener('click', () => {
                        currentIndex = index;
                        render({ keepListScroll: true });
                        if (window.matchMedia('(max-width: 860px)').matches) {
                            detailPanel?.scrollIntoView({ block: 'start', behavior: 'smooth' });
                        }
                    });

                    resultList.appendChild(button);
                });
            }

            function render(options = {}) {
                const filtered = getFilteredCards();

                if (currentIndex >= filtered.length) currentIndex = Math.max(0, filtered.length - 1);

                cards.forEach(card => setCardVisible(card, false));
                if (filtered[currentIndex]) setCardVisible(filtered[currentIndex], true);

                if (resultCount) {
                    const totalCount = filtered.length;
                    resultCount.textContent = currentQuery
                        ? `Найдено: ${totalCount}`
                        : `Всего направлений: ${cards.length}`;
                }

                if (noResults) noResults.hidden = filtered.length > 0;
                pagination.hidden = filtered.length === 0;
                prevButton.disabled = currentIndex <= 0;
                nextButton.disabled = currentIndex >= filtered.length - 1;
                pageStatus.textContent = filtered.length ? `${currentIndex + 1} из ${filtered.length}` : '0 из 0';

                buildResultList(filtered);

                if (!options.keepListScroll) {
                    const selected = resultList.querySelector('[aria-selected="true"]');
                    selected?.scrollIntoView({ block: 'nearest' });
                }
            }

            searchInput.addEventListener('input', () => {
                currentQuery = searchInput.value;
                currentIndex = 0;
                if (clearButton) clearButton.hidden = currentQuery.trim().length === 0;
                render();
            });

            clearButton?.addEventListener('click', () => {
                searchInput.value = '';
                currentQuery = '';
                currentIndex = 0;
                clearButton.hidden = true;
                searchInput.focus();
                render();
            });

            prevButton.addEventListener('click', () => {
                if (currentIndex > 0) {
                    currentIndex -= 1;
                    render();
                }
            });

            nextButton.addEventListener('click', () => {
                const filtered = getFilteredCards();
                if (currentIndex < filtered.length - 1) {
                    currentIndex += 1;
                    render();
                }
            });

            render();
        })();
    </script>
}
