<!-- _ScreenCharCreation.cshtml - step-by-step character creation -->
<div class="screen" id="screen-char-creation" style="width:100%;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;gap:1.5rem;">

    <div style="text-align:center">
        <h1 class="game-title" style="font-size:2rem;">Создание навигатора</h1>
        <p id="char-step-subtitle" style="color:var(--color-text-muted);margin-top:0.5rem;">Шаг 1: придумай никнейм.</p>
    </div>

    <form id="char-creation-form"
          style="display:flex;flex-direction:column;gap:1rem;width:min(900px,95vw);background:rgba(5,10,26,0.55);border:1px solid var(--color-border);border-radius:var(--radius);padding:clamp(1.1rem,1.4vw,1.8rem);"
          onsubmit="return false;">

        <div id="char-step-indicator" style="font-family:var(--font-display);font-size:0.75rem;letter-spacing:0.12em;color:var(--color-text-muted);text-align:center;">
            ШАГ 1 ИЗ 2
        </div>

        <section id="char-step-1" style="display:flex;flex-direction:column;gap:0.75rem;">
            <label for="navigator-name" style="font-family:var(--font-display);font-size:0.78rem;letter-spacing:0.1em;color:var(--color-text-muted);">НИКНЕЙМ</label>
            <input id="navigator-name" type="text" maxlength="24" placeholder="Введи никнейм..."
                   style="width:100%;padding:0.75rem 1rem;border-radius:var(--radius-sm);background:rgba(15,23,42,0.7);border:1px solid var(--color-border);color:var(--color-text);font-family:var(--font-body);font-size:1rem;outline:none;transition:border-color var(--transition-ui);"
                   oninput="document.getElementById('name-error').textContent=''" />
            <p id="name-error" style="color:#f87171;font-size:0.8rem;min-height:1em;"></p>
            <div style="display:flex;gap:0.75rem;justify-content:space-between;">
                <button type="button" class="btn-game btn-secondary" onclick="window._spa?.goBack()"
                        style="font-size:0.8rem;padding:0.6rem 0.9rem;">← Назад</button>
                <button type="button" class="btn-game btn-primary" onclick="window._charCreation?.nextFromName()">
                    Далее →
                </button>
            </div>
        </section>

        <section id="char-step-2" class="hidden" style="display:flex;flex-direction:column;gap:0.85rem;">
            <div id="ship-preview-viewport"
                 style="height:clamp(240px,42vh,420px);min-height:220px;border-radius:var(--radius-sm);border:1px solid var(--color-border);background:radial-gradient(circle at 50% 30%, rgba(79,195,247,0.16), rgba(2,7,16,0.82));position:relative;overflow:hidden;">
            </div>

            <p style="font-family:var(--font-display);font-size:0.78rem;letter-spacing:0.1em;color:var(--color-text-muted);">ЦВЕТ КОРАБЛЯ</p>
            <div id="ship-color-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0.65rem;">
                @foreach (var item in new[] {
                    (Name: "Синий",  Color: "#4fc3f7"),
                    (Name: "Красный",Color: "#f87171"),
                    (Name: "Зелёный",Color: "#34d399"),
                    (Name: "Золотой",Color: "#facc15")
                })
                {
                    <button type="button" class="ship-color-btn"
                            data-color="@item.Color"
                            data-name="@item.Name"
                            onclick="window._charCreation?.selectShipColor(this)"
                            title="@item.Name"
                            style="background:rgba(15,23,42,0.7);border:1px solid var(--color-border);border-radius:var(--radius-sm);padding:0.7rem;cursor:pointer;transition:border-color var(--transition-ui),box-shadow var(--transition-ui);display:flex;align-items:center;justify-content:center;gap:8px;">
                        <span style="display:inline-block;width:18px;height:18px;border-radius:50%;background:@item.Color;border:1px solid rgba(255,255,255,0.25);"></span>
                        <span style="font-size:0.85rem;color:var(--color-text);">@item.Name</span>
                    </button>
                }
            </div>
            <p id="ship-color-error" style="color:#f87171;font-size:0.8rem;min-height:1em;"></p>

            <div style="display:flex;gap:0.75rem;justify-content:space-between;">
                <button type="button" class="btn-game btn-secondary" onclick="window._charCreation?.backToName()"
                        style="font-size:0.8rem;padding:0.6rem 0.9rem;">← Назад к никнейму</button>
                <button id="btn-start-game" type="button" class="btn-game btn-primary" onclick="window._charCreation?.submit()">
                    Начать путешествие 🚀
                </button>
            </div>
        </section>
    </form>
</div>
