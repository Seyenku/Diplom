<!-- _ScreenAchievements.cshtml — Достижения и аналитика прогресса -->
<div class="screen" id="screen-achievements"
     style="width:100%;min-height:100vh;display:flex;flex-direction:column;padding:2rem;gap:1.5rem;">

    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <h1 class="game-title" style="font-size:1.5rem;">📊 Достижения и прогресс</h1>
        <button class="btn-game btn-secondary" onclick="window._spa?.goBack()" style="padding:8px 16px;font-size:0.8rem;">← Назад</button>
    </div>

    <!-- Сводная статистика -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;">
        <div class="game-card" style="text-align:center;">
            <p style="font-size:2rem;">🌍</p>
            <p id="stat-planets" style="font-family:var(--font-display);font-size:1.5rem;color:var(--color-primary);">0</p>
            <p style="font-size:0.75rem;color:var(--color-text-muted);">Открыто планет</p>
        </div>
        <div class="game-card" style="text-align:center;">
            <p style="font-size:2rem;">🔭</p>
            <p id="stat-scans" style="font-family:var(--font-display);font-size:1.5rem;color:var(--color-accent);">0</p>
            <p style="font-size:0.75rem;color:var(--color-text-muted);">Сканирований</p>
        </div>
        <div class="game-card" style="text-align:center;">
            <p style="font-size:2rem;">🎮</p>
            <p id="stat-minigames" style="font-family:var(--font-display);font-size:1.5rem;color:var(--color-crystal1);">0</p>
            <p style="font-size:0.75rem;color:var(--color-text-muted);">Мини-игр пройдено</p>
        </div>
        <div class="game-card" style="text-align:center;">
            <p style="font-size:2rem;">💎</p>
            <p id="stat-total-crystals" style="font-family:var(--font-display);font-size:1.5rem;color:#fb923c;">0</p>
            <p style="font-size:0.75rem;color:var(--color-text-muted);">Кристаллов собрано</p>
        </div>
    </div>

    <!-- График активности по направлениям (bar-chart svg) -->
    <div class="game-card">
        <h3 style="font-family:var(--font-display);font-size:0.85rem;letter-spacing:0.05em;color:var(--color-text-muted);margin-bottom:1rem;">АКТИВНОСТЬ ПО НАПРАВЛЕНИЯМ</h3>
        <svg id="activity-chart" viewBox="0 0 600 120" style="width:100%;height:auto;">
            <!-- JS рендерит столбики -->
        </svg>
    </div>

    <!-- Список достижений -->
    <div>
        <h2 style="font-family:var(--font-display);font-size:0.9rem;letter-spacing:0.05em;color:var(--color-text-muted);margin-bottom:0.75rem;">ДОСТИЖЕНИЯ</h2>
        <div id="achievements-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;">
            <!-- JS рендерит значки -->
        </div>
    </div>

    <button id="btn-export-stats" class="btn-game btn-secondary" onclick="window._achievements?.exportStats()" style="align-self:flex-start;">
        📥 Экспорт статистики
    </button>
</div>
