<!-- _ScreenAchievements.cshtml — Достижения, Radar Chart и аналитика -->
<div class="screen" id="screen-achievements"
     style="width:100%;min-height:100vh;display:flex;flex-direction:column;padding:1.5rem;gap:1.25rem;">

    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <h1 class="game-title" style="font-size:1.4rem;">📊 Прогресс навигатора</h1>
        <button class="btn-game btn-secondary" onclick="window._spa?.goBack()" style="padding:6px 14px;font-size:0.78rem;">← Назад</button>
    </div>

    <!-- Сводные карточки статистики -->
    <div class="achievements-stats-grid">
        <div class="stats-card">
            <div class="stats-card-icon">🌍</div>
            <div id="stat-planets" class="stats-card-value">0</div>
            <div class="stats-card-label">Открыто планет</div>
        </div>
        <div class="stats-card">
            <div class="stats-card-icon">🔭</div>
            <div id="stat-scans" class="stats-card-value stats-card-value--accent">0</div>
            <div class="stats-card-label">Сканирований</div>
        </div>
        <div class="stats-card">
            <div class="stats-card-icon">🎮</div>
            <div id="stat-minigames" class="stats-card-value stats-card-value--crystal">0</div>
            <div class="stats-card-label">Мини-игр</div>
        </div>
        <div class="stats-card">
            <div class="stats-card-icon">💎</div>
            <div id="stat-total-crystals" class="stats-card-value stats-card-value--orange">0</div>
            <div class="stats-card-label">Кристаллов</div>
        </div>
        <div class="stats-card">
            <div class="stats-card-icon">🚀</div>
            <div id="stat-flights" class="stats-card-value stats-card-value--green">0</div>
            <div class="stats-card-label">Полётов</div>
        </div>
    </div>

    <!-- Radar Chart — профиль навигатора -->
    <div class="game-card" style="display:flex;flex-direction:column;align-items:center;gap:1rem;">
        <h3 class="achievements-section-title">ПРОФИЛЬ НАВИГАТОРА</h3>
        <p class="achievements-section-desc">Распределение кристаллов по направлениям</p>
        <svg id="radar-chart" viewBox="0 0 400 400" style="width:min(360px,90vw);height:auto;"></svg>
    </div>

    <!-- Bar chart — активность по направлениям -->
    <div class="game-card">
        <h3 class="achievements-section-title">АКТИВНОСТЬ ПО НАПРАВЛЕНИЯМ</h3>
        <svg id="activity-chart" viewBox="0 0 600 140" style="width:100%;height:auto;"></svg>
    </div>

    <!-- Достижения -->
    <div>
        <h2 class="achievements-section-title" style="margin-bottom:0.75rem;">ДОСТИЖЕНИЯ</h2>
        <div id="achievements-grid" class="achievements-badge-grid">
            <!-- JS рендерит значки -->
        </div>
    </div>

    <!-- Экспорт -->
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        <button id="btn-export-stats" class="btn-game btn-secondary" onclick="window._achievements?.exportStats()" style="font-size:0.78rem;">
            📥 Экспорт статистики
        </button>
        <button class="btn-game btn-secondary" onclick="window._spa?.goto('vocation-constellation')" style="font-size:0.78rem;">
            🌠 Созвездие Призвания
        </button>
    </div>
</div>
