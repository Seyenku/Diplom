<!-- _ScreenAchievements.cshtml — Прогресс навигатора (redesign) -->
<div class="screen" id="screen-achievements"
     style="width:100%;min-height:100vh;display:flex;flex-direction:column;padding:1.5rem;gap:0;">

    <div class="container-fluid px-0">

        <!-- ═══ Header ═══════════════════════════════════════════ -->
        <div class="ach-header d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
            <div>
                <h1 class="game-title" style="font-size:1.5rem;margin:0;">🏆 Прогресс навигатора</h1>
                <div class="d-flex align-items-center gap-2 mt-1">
                    <span id="ach-player-name" class="ach-player-name">Навигатор</span>
                    <span id="ach-rank" class="ach-rank-badge">Кадет</span>
                </div>
            </div>
            <button id="btn-export-stats" class="btn-game btn-secondary" onclick="window._achievements?.exportStats()" style="font-size:0.78rem;">
                📥 Экспорт
            </button>
        </div>

        <!-- ═══ Stats Row ════════════════════════════════════════ -->
        <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
            <div class="col ach-stat-appear" style="--delay:0">
                <div class="ach-stat-card">
                    <div class="ach-stat-icon" style="--glow:#4fc3f7;">🌍</div>
                    <div id="stat-planets" class="ach-stat-value">0</div>
                    <div class="ach-stat-label">Открыто планет</div>
                </div>
            </div>
            <div class="col ach-stat-appear" style="--delay:1">
                <div class="ach-stat-card">
                    <div class="ach-stat-icon" style="--glow:#c084fc;">🎮</div>
                    <div id="stat-minigames" class="ach-stat-value">0</div>
                    <div class="ach-stat-label">Мини-игр</div>
                </div>
            </div>
            <div class="col ach-stat-appear" style="--delay:2">
                <div class="ach-stat-card">
                    <div class="ach-stat-icon" style="--glow:#fb923c;">💎</div>
                    <div id="stat-total-crystals" class="ach-stat-value">0</div>
                    <div class="ach-stat-label">Кристаллов</div>
                </div>
            </div>
            <div class="col ach-stat-appear" style="--delay:3">
                <div class="ach-stat-card">
                    <div class="ach-stat-icon" style="--glow:#4ade80;">🚀</div>
                    <div id="stat-flights" class="ach-stat-value">0</div>
                    <div class="ach-stat-label">Полётов</div>
                </div>
            </div>
        </div>

        <!-- ═══ Charts Row ═══════════════════════════════════════ -->
        <div class="row g-3 mb-4">
            <!-- Crystal Distribution (progress bars) -->
            <div class="col-lg-5">
                <div class="game-card ach-chart-card h-100">
                    <h3 class="ach-section-title">💎 КРИСТАЛЛЫ ПО НАПРАВЛЕНИЯМ</h3>
                    <div id="ach-crystal-bars" class="d-flex flex-column gap-3 mt-3">
                        <!-- JS renders bars -->
                    </div>
                </div>
            </div>
            <!-- Radar Chart -->
            <div class="col-lg-7">
                <div class="game-card ach-chart-card ach-radar-wrap h-100 d-flex flex-column align-items-center justify-content-center">
                    <h3 class="ach-section-title">🕸️ ПРОФИЛЬ НАВИГАТОРА</h3>
                    <p class="ach-section-desc">Распределение кристаллов по направлениям</p>
                    <svg id="radar-chart" viewBox="0 0 400 400" class="ach-radar-svg"></svg>
                </div>
            </div>
        </div>

        <!-- ═══ Achievements ═════════════════════════════════════ -->
        <div class="mb-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <h2 class="ach-section-title m-0">🏅 ДОСТИЖЕНИЯ</h2>
                <span id="ach-counter" class="ach-counter-badge">0 / 10</span>
            </div>
            <div id="achievements-grid" class="row row-cols-1 row-cols-sm-2 g-3">
                <!-- JS renders badges -->
            </div>
        </div>

        <!-- ═══ CTA Footer ═══════════════════════════════════════ -->
        <div class="ach-cta-card" data-spa="goto" data-screen="vocation-constellation" style="cursor:pointer;">
            <div class="d-flex align-items-center gap-3">
                <span class="ach-cta-icon">🌠</span>
                <div>
                    <div class="ach-cta-title">Созвездие Призвания</div>
                    <div class="ach-cta-desc">Посмотри, к какой профессии ты ближе всего</div>
                </div>
            </div>
            <span class="ach-cta-arrow">→</span>
        </div>
    </div>
</div>
