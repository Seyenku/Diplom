<!-- _ScreenMiniGameGeology.cshtml — Мини-игра «Анализ породы» (Туманность Геодезистов) -->
<div class="screen" id="screen-minigame-geology">

    <!-- Шапка -->
    <header class="geo-header">
        <div class="geo-header-title">🌍 Туманность Геодезистов — Анализ породы</div>
        <div class="geo-header-info">
            <div class="geo-header-stat">
                <p>ФАЗА</p>
                <p id="geo-phase-label" style="color:#7a9e50;">Кат-сцена</p>
            </div>
            <div class="geo-header-stat">
                <p>ЗОНД</p>
                <p id="geo-probe-status" style="color:#facc15;">🛸 В полёте</p>
            </div>
            <button class="btn-game btn-secondary" style="padding:0.375rem 0.75rem;font-size:0.8rem;"
                    onclick="window._miniGameGeology?.returnToPlanet()">
                ← Выйти
            </button>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════════
         ФАЗА 1: КАТ-СЦЕНА (3D)
         ═══════════════════════════════════════════════ -->
    <div id="geo-phase-cutscene" style="flex:1;position:relative;overflow:hidden;">

        <canvas id="geo-cutscene-canvas" style="width:100%;height:100%;display:block;"></canvas>

        <div id="geo-cutscene-ui" style="
            position:absolute;inset:0;
            display:flex;flex-direction:column;
            align-items:center;justify-content:flex-end;
            padding:2.5rem 2rem;gap:1.25rem;
            pointer-events:none;
            background:linear-gradient(to top, rgba(2,7,16,0.88) 0%, transparent 50%);
        ">
            <div class="geo-cutscene-text" style="text-align:center;max-width:560px;">
                <h2 id="geo-cutscene-headline" style="font-size:clamp(1.1rem,1.5vw + 0.8rem,1.7rem);margin-bottom:0.35rem;color:#fff;text-shadow:0 2px 12px rgba(0,0,0,0.8);">
                    Приближение к планете...
                </h2>
                <p id="geo-cutscene-subtext" style="font-size:clamp(0.85rem,0.3vw + 0.78rem,1rem);color:rgba(203,213,225,0.85);line-height:1.5;text-shadow:0 1px 8px rgba(0,0,0,0.7);">
                    Корабль выходит на орбиту Туманности Геодезистов
                </p>
            </div>

            <div id="geo-cutscene-alert" class="geo-cutscene-alert hidden"
                 style="pointer-events:none;">
                ⚠️ Астероидный пояс блокирует орбиту!
            </div>

            <div class="geo-cutscene-progress" style="width:min(340px,80vw);">
                <div id="geo-cutscene-progress-bar" class="geo-cutscene-progress-bar" style="width:0%;"></div>
            </div>
        </div>

        <!-- Вспышка при запуске зонда -->
        <div id="geo-hit-flash" style="
            position:absolute;inset:0;
            background:radial-gradient(ellipse at center, #a8c878 0%, #7a9e50 40%, transparent 70%);
            opacity:0;pointer-events:none;transition:opacity 0.25s ease-out;
        "></div>
    </div>


    <!-- ═══════════════════════════════════════════════
         ФАЗА 2: АНАЛИЗ ПОРОДЫ
         ═══════════════════════════════════════════════ -->
    <div id="geo-phase-analysis" class="hidden">

        <!-- Колонка 1: Метрики породы -->
        <div class="geo-metrics-col">
            <p class="geo-section-title">📊 Метрики породы</p>

            <div id="metric-hardness" class="geo-metric-card">
                <span class="geo-metric-icon">💎</span>
                <div class="geo-metric-info">
                    <span class="geo-metric-name">Твёрдость</span>
                    <div class="geo-metric-bar">
                        <div id="metric-hardness-bar" class="geo-metric-bar-fill normal" style="width:40%;"></div>
                    </div>
                </div>
                <span id="metric-hardness-val" class="geo-metric-value normal">4 / 10</span>
            </div>

            <div id="metric-temp" class="geo-metric-card">
                <span class="geo-metric-icon">🌡️</span>
                <div class="geo-metric-info">
                    <span class="geo-metric-name">Температура</span>
                    <div class="geo-metric-bar">
                        <div id="metric-temp-bar" class="geo-metric-bar-fill normal" style="width:30%;"></div>
                    </div>
                </div>
                <span id="metric-temp-val" class="geo-metric-value normal">+20 °C</span>
            </div>

            <div id="metric-rad" class="geo-metric-card">
                <span class="geo-metric-icon">☢️</span>
                <div class="geo-metric-info">
                    <span class="geo-metric-name">Радиоактивность</span>
                    <div class="geo-metric-bar">
                        <div id="metric-rad-bar" class="geo-metric-bar-fill normal" style="width:10%;"></div>
                    </div>
                </div>
                <span id="metric-rad-val" class="geo-metric-value normal">0.2 мЗв/ч</span>
            </div>

            <div id="metric-pore" class="geo-metric-card">
                <span class="geo-metric-icon">🕳️</span>
                <div class="geo-metric-info">
                    <span class="geo-metric-name">Пористость</span>
                    <div class="geo-metric-bar">
                        <div id="metric-pore-bar" class="geo-metric-bar-fill normal" style="width:15%;"></div>
                    </div>
                </div>
                <span id="metric-pore-val" class="geo-metric-value normal">12%</span>
            </div>

            <!-- Нормальные диапазоны -->
            <div style="padding:0.65rem 0.85rem;background:rgba(15,23,42,0.5);border:1px solid rgba(255,255,255,0.06);border-radius:var(--radius-sm);margin-top:auto;">
                <p style="font-size:0.7rem;color:var(--color-text-muted);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.4rem;">Норма для бурения</p>
                <p style="font-size:0.78rem;color:#64748b;line-height:1.6;font-family:monospace;">
                    💎 3–6 по Моосу &nbsp;|&nbsp; 🌡️ −50…+200 °C<br>
                    ☢️ &lt; 0.5 мЗв/ч &nbsp;|&nbsp; 🕳️ &lt; 20%
                </p>
            </div>
        </div>

        <!-- Колонка 2: Стратиграфический разрез (Canvas) -->
        <div class="geo-strata-col">
            <p class="geo-section-title">🪨 Стратиграфический разрез</p>
            <canvas id="geo-strata-canvas" class="geo-strata-canvas"></canvas>
            <div class="geo-sample-info">
                <p id="geo-sample-name" class="geo-sample-name">Загрузка...</p>
                <p id="geo-sample-desc" class="geo-sample-desc">Анализ данных зонда...</p>
            </div>
        </div>

        <!-- Колонка 3: Метод бурения -->
        <div class="geo-method-col">
            <p class="geo-section-title">⛏️ Метод бурения</p>

            <div id="geo-method-list" class="geo-method-list">
                <!-- Карточки вставляются через JS -->
            </div>

            <button id="geo-submit-btn" class="geo-submit-btn" disabled
                    onclick="window._miniGameGeology?.submitMethod()">
                ⛏ Начать бурение
            </button>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         OVERLAY: БУРЕНИЕ + РАСКОЛ (absolute)
         ═══════════════════════════════════════════════ -->
    <div id="geo-split-overlay" class="geo-split-overlay hidden">
        <canvas id="geo-split-canvas" class="geo-split-canvas"></canvas>
        <div class="geo-drill-info">
            <p id="geo-drill-label" class="geo-drill-label">⛏ БУРЕНИЕ...</p>
            <div class="geo-drill-bar-track">
                <div id="geo-drill-bar" class="geo-drill-bar"></div>
            </div>
        </div>
        <div id="geo-split-flash" class="geo-split-flash"></div>
    </div>

    <!-- ═══════════════════════════════════════════════
         ФАЗА 3: РЕЗУЛЬТАТ
         ═══════════════════════════════════════════════ -->
    <div id="geo-phase-result" class="hidden">
        <div id="geo-result-icon" class="geo-result-icon">✅</div>
        <h2 id="geo-result-title" class="geo-result-title success">Проход открыт!</h2>
        <p id="geo-result-text" class="geo-result-text">Астероид расколот. Посадочная орбита свободна.</p>
        <div id="geo-result-correct-wrap" class="geo-result-correct hidden">
            Правильный метод: <strong id="geo-result-correct-name"></strong>
        </div>
        <div class="geo-result-actions">
            <button id="geo-btn-return" class="btn-game btn-primary"
                    onclick="window._miniGameGeology?.returnToPlanet()">
                ← Вернуться к планете
            </button>
        </div>
    </div>

</div>
