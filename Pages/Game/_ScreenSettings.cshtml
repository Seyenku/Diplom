<!-- _ScreenSettings.cshtml — Настройки и доступность -->
<div class="screen" id="screen-settings"
     style="width:100%;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:2rem;gap:1.5rem;">

    <div style="width:100%;max-width:560px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
            <h1 class="game-title" style="font-size:1.5rem;">⚙ Настройки</h1>
        </div>

        <div style="display:flex;flex-direction:column;gap:1rem;">

            <!-- Звук -->
            <div class="game-card">
                <h3 style="font-family:var(--font-display);font-size:0.78rem;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.75rem;">ЗВУК</h3>
                <div style="display:flex;flex-direction:column;gap:0.75rem;">
                    <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Громкость звука</span>
                        <input type="range" id="setting-sound" min="0" max="100" value="70"
                               oninput="window._settings?.update('soundVolume',this.value)"
                               style="width:8.75rem;accent-color:var(--color-primary);" />
                    </label>
                    <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Громкость музыки</span>
                        <input type="range" id="setting-music" min="0" max="100" value="50"
                               oninput="window._settings?.update('musicVolume',this.value)"
                               style="width:8.75rem;accent-color:var(--color-primary);" />
                    </label>
                </div>
            </div>

            <!-- Графика -->
            <div class="game-card">
                <h3 style="font-family:var(--font-display);font-size:0.78rem;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.75rem;">ГРАФИКА</h3>
                <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                    <span style="font-size:0.9rem;">Качество графики</span>
                    <select id="setting-graphics" onchange="window._settings?.update('graphicsQuality',this.value)"
                            style="background:rgba(15,23,42,0.8);border:1px solid var(--color-border);color:var(--color-text);border-radius:var(--radius-sm);padding:0.375rem 0.625rem;">
                        <option value="low">Низкое</option>
                        <option value="medium" selected>Среднее</option>
                        <option value="high">Высокое</option>
                    </select>
                </label>
                <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;cursor:pointer;margin-top:0.75rem;">
                    <span style="font-size:0.9rem;">Включить свечение (Bloom)</span>
                    <input type="checkbox" id="setting-bloom" checked
                           onchange="window._settings?.update('useBloom',this.checked)"
                           style="width:1.125rem;height:1.125rem;accent-color:var(--color-primary);" />
                </label>
            </div>

            <!-- Управление -->
            <div class="game-card">
                <h3 style="font-family:var(--font-display);font-size:0.78rem;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.75rem;">УПРАВЛЕНИЕ</h3>
                <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                    <span style="font-size:0.9rem;">Схема управления</span>
                    <select id="setting-controls" onchange="window._settings?.update('controlScheme',this.value)"
                            style="background:rgba(15,23,42,0.8);border:1px solid var(--color-border);color:var(--color-text);border-radius:var(--radius-sm);padding:0.375rem 0.625rem;">
                        <option value="keyboard" selected>Клавиатура</option>
                        <option value="mouse">Мышь</option>
                    </select>
                </label>

                <div id="settings-keybindings-block" style="display:flex;flex-direction:column;gap:0.75rem;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.1);transition:opacity 0.3s;">
                    <h4 style="font-size:0.85rem;color:var(--color-text-muted);margin-bottom:0.25rem;">ГОРЯЧИЕ КЛАВИШИ</h4>
                    
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Вперед</span>
                        <button class="btn-game" id="bind-up" onclick="window._settings?.startBind('up')" style="padding:0.25rem 0.75rem;min-width:6rem;text-align:center;font-family:monospace;font-size:0.9rem;border:1px solid var(--color-border);background:rgba(15,23,42,0.5);">W</button>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Назад</span>
                        <button class="btn-game" id="bind-down" onclick="window._settings?.startBind('down')" style="padding:0.25rem 0.75rem;min-width:6rem;text-align:center;font-family:monospace;font-size:0.9rem;border:1px solid var(--color-border);background:rgba(15,23,42,0.5);">S</button>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Влево</span>
                        <button class="btn-game" id="bind-left" onclick="window._settings?.startBind('left')" style="padding:0.25rem 0.75rem;min-width:6rem;text-align:center;font-family:monospace;font-size:0.9rem;border:1px solid var(--color-border);background:rgba(15,23,42,0.5);">A</button>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Вправо</span>
                        <button class="btn-game" id="bind-right" onclick="window._settings?.startBind('right')" style="padding:0.25rem 0.75rem;min-width:6rem;text-align:center;font-family:monospace;font-size:0.9rem;border:1px solid var(--color-border);background:rgba(15,23,42,0.5);">D</button>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Ускорение</span>
                        <button class="btn-game" id="bind-boost" onclick="window._settings?.startBind('boost')" style="padding:0.25rem 0.75rem;min-width:6rem;text-align:center;font-family:monospace;font-size:0.9rem;border:1px solid var(--color-border);background:rgba(15,23,42,0.5);">Space</button>
                    </div>
                </div>
            </div>

            <!-- Доступность -->
            <div class="game-card">
                <h3 style="font-family:var(--font-display);font-size:0.78rem;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.75rem;">ДОСТУПНОСТЬ</h3>
                <div style="display:flex;flex-direction:column;gap:0.75rem;">
                    <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;cursor:pointer;">
                        <span style="font-size:0.9rem;">Подсказки Гайда</span>
                        <input type="checkbox" id="setting-guide" checked
                               onchange="window._settings?.update('guideEnabled',this.checked)"
                               style="width:1.125rem;height:1.125rem;accent-color:var(--color-primary);" />
                    </label>
                    <label style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                        <span style="font-size:0.9rem;">Масштаб UI</span>
                        <input type="range" id="setting-uiscale" min="80" max="130" value="100"
                               oninput="window._settings?.update('uiScale',this.value/100)"
                               style="width:8.75rem;accent-color:var(--color-primary);" />
                    </label>
                </div>
            </div>

            <button class="btn-game btn-primary" onclick="window._settings?.saveAndApply()">
                ✓ Применить и сохранить
            </button>
        </div>
    </div>
</div>
