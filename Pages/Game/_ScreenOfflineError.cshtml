<!-- _ScreenOfflineError.cshtml — Офлайн / ошибка синхронизации -->
<div class="screen" id="screen-offline-error"
     style="width:100%;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;padding:2rem;">

    <div style="text-align:center;max-width:460px;">
        <div style="font-size:4rem;margin-bottom:1rem;">📡</div>
        <h1 class="game-title" style="font-size:1.5rem;color:#f87171;">Ошибка соединения</h1>
        <p id="offline-error-message" style="color:var(--color-text-muted);margin-top:0.75rem;line-height:1.7;font-size:0.95rem;">
            Не удалось установить соединение с сервером. Проверь подключение к интернету и попробуй снова.
        </p>
    </div>

    <div class="game-card" style="max-width:460px;width:100%;font-size:0.85rem;line-height:1.8;">
        <h3 style="font-family:var(--font-display);font-size:0.75rem;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.5rem;">ЧТО ДЕЛАТЬ:</h3>
        <ol style="padding-left:1.25rem;color:var(--color-text-muted);display:flex;flex-direction:column;gap:0.25rem;">
            <li>Проверь Wi-Fi или мобильное соединение.</li>
            <li>Перезагрузи страницу кнопкой «Попробовать снова».</li>
            <li>Если проблема не исчезла — свяжись с поддержкой.</li>
        </ol>
    </div>

    <!-- Лог ошибки (опционально) -->
    <details style="max-width:460px;width:100%;">
        <summary style="cursor:pointer;color:var(--color-text-muted);font-size:0.8rem;margin-bottom:0.5rem;">Технические детали</summary>
        <pre id="offline-error-log"
             style="background:rgba(5,10,26,0.8);border:1px solid var(--color-border);border-radius:var(--radius-sm);padding:1rem;font-size:0.75rem;color:#94a3b8;overflow:auto;max-height:120px;"></pre>
    </details>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
        <button class="btn-game btn-primary" onclick="location.reload()">
            ↻ Попробовать снова
        </button>
        <button class="btn-game btn-secondary" onclick="window._spa?.goto('main-menu')">
            🏠 Главное меню
        </button>
    </div>
</div>
