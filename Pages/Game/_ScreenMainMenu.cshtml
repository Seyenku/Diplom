<!-- _ScreenMainMenu.cshtml — Главное меню Stellar Vocation -->
<div class="screen starfield" id="screen-main-menu" style="width:100%;height:100%;min-height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2.2rem;padding:2.2rem;">

    <!-- Лого / Заголовок -->
    <div style="text-align:center;">
        <p class="game-subtitle" style="margin-bottom:0.6rem;font-size:clamp(0.82rem,0.4vw,1.02rem);letter-spacing:0.26em;">Stellar Vocation</p>
        <h1 class="game-title" style="font-size:clamp(2.4rem,5.3vw,5rem);line-height:1.05;">
            Галактика<br>Призвания
        </h1>
        <p style="color:var(--color-text-muted);margin-top:1rem;max-width:680px;font-size:clamp(1rem,0.5vw,1.22rem);line-height:1.65;">
            Образовательное космическое приключение.<br>Исследуй профессии будущего и найди своё призвание.
        </p>
    </div>

    <!-- Кнопки -->
    <div style="display:flex;flex-direction:column;gap:1rem;width:min(420px,92vw);">
        <button id="btn-new-game" class="btn-game btn-primary" data-spa="newGame">
            🚀 Новая игра
        </button>
        <button id="btn-continue" class="btn-game btn-secondary" data-spa="continueGame" style="display:none">
            ▶ Продолжить
        </button>
        <button id="btn-settings-menu" class="btn-game btn-secondary" data-spa="goto" data-screen="settings">
            ⚙ Настройки
        </button>
    </div>

    <!-- Лор-карточки -->
    <div class="lore-cards">
        <div class="lore-card">
            <div class="lore-card-icon">🚀</div>
            <div class="lore-card-title">Звёздный Навигатор</div>
            <div class="lore-card-text">Ты — последний Навигатор Академии. Исследуй Галактику и собирай Кристаллы Знаний.</div>
        </div>
        <div class="lore-card">
            <div class="lore-card-icon">💎</div>
            <div class="lore-card-title">Кристаллы Знаний</div>
            <div class="lore-card-text">Каждый кристалл отвечает за направление: IT, медицина, экология, дизайн и другие.</div>
        </div>
        <div class="lore-card">
            <div class="lore-card-icon">🌍</div>
            <div class="lore-card-title">Планеты-Профессии</div>
            <div class="lore-card-text">Открывай планеты-профессии, проходи испытания и узнай, какая специальность — твоя.</div>
        </div>
    </div>

    <!-- CTA Университет -->
    <a href="https://www.syktsu.ru/" target="_blank" rel="noopener noreferrer" class="btn-cta-university">
        🎓 Поступление в СГУ им. Питирима Сорокина
    </a>

    <!-- Версия -->
    <p style="position:absolute;bottom:1.5rem;color:var(--color-text-muted);font-size:clamp(0.8rem,0.25vw,0.95rem);opacity:0.5;">
        v0.2.0 Alpha &nbsp;|&nbsp; Stellar Vocation
    </p>
</div>
