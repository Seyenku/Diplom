<!-- _ScreenMainMenu.cshtml — Главное меню Stellar Vocation -->
<div class="screen starfield" id="screen-main-menu" style="width:100%;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2rem;">

    <!-- Лого / Заголовок -->
    <div style="text-align:center;">
        <p class="game-subtitle" style="margin-bottom:0.5rem;font-size:0.75rem;letter-spacing:0.3em;">Stellar Vocation</p>
        <h1 class="game-title" style="font-size:clamp(2rem,5vw,4rem);line-height:1.1;">
            Галактика<br>Призвания
        </h1>
        <p style="color:var(--color-text-muted);margin-top:1rem;max-width:460px;font-size:0.95rem;line-height:1.6;">
            Образовательное космическое приключение.<br>Исследуй профессии будущего и найди своё призвание.
        </p>
    </div>

    <!-- Кнопки -->
    <div style="display:flex;flex-direction:column;gap:1rem;width:min(280px,90vw);">
        <button id="btn-new-game" class="btn-game btn-primary" onclick="window._spa?.newGame()">
            🚀 Новая игра
        </button>
        <button id="btn-continue" class="btn-game btn-secondary" onclick="window._spa?.continueGame()" style="display:none">
            ▶ Продолжить
        </button>
        <button id="btn-settings-menu" class="btn-game btn-secondary" onclick="window._spa?.openSettings()">
            ⚙ Настройки
        </button>
    </div>

    <!-- Версия -->
    <p style="position:absolute;bottom:1.5rem;color:var(--color-text-muted);font-size:0.75rem;opacity:0.5;">
        v0.1.0 Alpha &nbsp;|&nbsp; Stellar Vocation
    </p>
</div>
