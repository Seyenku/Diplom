<!-- _ScreenMiniGame.cshtml — Экран мини-игры (пробная посадка) -->
<div class="screen" id="screen-minigame"
     style="width:100%;height:100vh;display:flex;flex-direction:column;background:#020710;">

    <!-- Шапка мини-игры -->
    <header style="display:flex;align-items:center;justify-content:flex-end;padding:0.75rem 1.5rem;background:rgba(5,10,26,0.85);border-bottom:1px solid var(--color-border);">
        <div style="display:flex;align-items:center;gap:1.5rem;">
            <!-- Здоровье -->
            <div style="text-align:right;">
                <p style="font-size:0.7rem;color:var(--color-text-muted);">ЗДОРОВЬЕ</p>
                <p id="mg-health" style="font-family:var(--font-display);font-size:1.2rem;color:#4ade80;">100%</p>
            </div>
            <!-- Таймер -->
            <div style="text-align:right;">
                <p style="font-size:0.7rem;color:var(--color-text-muted);">ВРЕМЯ</p>
                <p id="mg-timer" style="font-family:var(--font-display);font-size:1.2rem;color:var(--color-accent);">30</p>
            </div>
            <!-- Пауза -->
            <button class="btn-game btn-secondary" onclick="window._miniGame?.pause()" style="padding:0.375rem 0.75rem;font-size:0.8rem;">⏸</button>
        </div>
    </header>

    <!-- Игровое поле (canvas мини-игры, поверх Three.js) -->
    <div style="flex:1;position:relative;overflow:hidden;">
        <canvas id="minigame-canvas" style="width:100%;height:100%;display:block;"></canvas>

        <!-- Результат по завершении -->
        <div id="mg-result-overlay" class="hidden"
             style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;background:rgba(2,7,16,0.9);backdrop-filter:blur(8px);">
            <div id="mg-result-icon" style="font-size:4rem;">🎉</div>
            <h2 id="mg-result-title" class="game-title" style="font-size:1.5rem;">Посадка выполнена!</h2>
            <p id="mg-result-text" style="color:var(--color-text-muted);text-align:center;max-width:360px;line-height:1.6;"></p>
            <div id="mg-reward-badges" style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;"></div>
            <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
                <button class="btn-game btn-primary" onclick="window._miniGame?.returnToPlanet()">← Вернуться к планете</button>
                <button class="btn-game btn-secondary" onclick="window._miniGame?.retry()">↻ Ещё раз</button>
            </div>
        </div>
    </div>
</div>
