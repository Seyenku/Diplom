<!-- _GameNavbar.cshtml - Сквозная навигация SPA -->
<nav id="game-navbar" class="game-navbar hidden" aria-label="Навигация игры">
    <!-- Кнопка «Назад» — вне flex-потока, не влияет на центрирование основных кнопок.
         Видима только в режиме просмотра туманности на карте галактики. -->
    <button id="nav-btn-back" class="nav-btn nav-btn--icon nav-btn--back-overlay hidden"
            type="button" title="Назад" aria-label="Назад"
            onclick="window._galaxyMap?.backToOverview()">
        <span class="nav-icon">←</span>
    </button>
    <button class="nav-btn" data-spa="goto" data-screen="galaxy-map" title="Звёздная карта">
        <span class="nav-icon">🌌</span>
        <span class="nav-label">Карта</span>
    </button>
    <button class="nav-btn" data-spa="goto" data-screen="achievements" title="Прогресс">
        <span class="nav-icon">📊</span>
        <span class="nav-label">Прогресс</span>
    </button>
    <button class="nav-btn" data-spa="goto" data-screen="ship-upgrade" title="Корабль">
        <span class="nav-icon">🛸</span>
        <span class="nav-label">Корабль</span>
    </button>
    <button class="nav-btn" data-spa="goto" data-screen="settings" title="Настройки">
        <span class="nav-icon">⚙️</span>
        <span class="nav-label">Настройки</span>
    </button>
</nav>
