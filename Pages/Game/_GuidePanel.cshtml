<!-- _GuidePanel.cshtml — ИИ «Гайд» — чат/журнал сообщений -->
<div id="guide-panel-inner" style="display:flex;flex-direction:column;height:100%;">

    <!-- Шапка -->
    <div style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;border-bottom:1px solid var(--color-border);background:rgba(10,15,30,0.5);">
        <div style="font-size:1.5rem;">🤖</div>
        <div style="flex:1;">
            <p style="font-family:var(--font-display);font-size:0.8rem;color:var(--color-primary);">ГАЙД</p>
            <p style="font-size:0.7rem;color:var(--color-text-muted);">Бортовой ИИ-советник</p>
        </div>
        <button data-spa="toggleGuide"
                style="background:transparent;border:none;color:var(--color-text-muted);cursor:pointer;font-size:1rem;padding:0.25rem;line-height:1;transition:color var(--transition-ui);"
                title="Закрыть">✕</button>
    </div>

    <!-- Поток сообщений -->
    <div id="guide-messages"
         style="flex:1;overflow-y:auto;padding:0.75rem;display:flex;flex-direction:column;gap:0.6rem;">
        <!-- JS добавляет сообщения через addGuideMessage() -->
    </div>

    <!-- Быстрые подсказки (теги) -->
    <div id="guide-quick-hints"
         style="padding:0.5rem 0.75rem;border-top:1px solid var(--color-border);display:flex;flex-wrap:wrap;gap:0.4rem;">
        <!-- JS рендерит кнопки-теги быстрых вопросов -->
    </div>
</div>
