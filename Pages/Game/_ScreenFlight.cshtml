<!-- _ScreenFlight.cshtml — Экран полёта / сбор кристаллов -->
<div class="screen" id="screen-flight" style="width:100%;height:100%;position:relative;">

    <!-- Оверлей обратного отсчёта (Стейт 1) -->
    <div id="flight-countdown" class="flight-countdown-overlay">
        <div class="countdown-number" id="countdown-number">3</div>
        <p class="countdown-subtitle">Приготовьтесь к полёту, Навигатор!</p>
    </div>

    <!-- HUD полёта (Стейт 2) — поверх Three.js canvas -->
    <div id="flight-hud" class="flight-hud hidden">
        <!-- Верхний левой — кристаллы текущей сессии -->
        <div class="flight-hud-top">
            <div class="flight-stat-group">
                <span class="flight-stat-icon">💎</span>
                <span id="flight-crystals-count" class="flight-stat-value">0</span>
            </div>
            <div class="flight-stat-group">
                <span class="flight-stat-icon">🛡</span>
                <div class="flight-bar-track">
                    <div id="flight-shield-bar" class="flight-bar-fill flight-bar-shield" style="width:100%"></div>
                </div>
            </div>
            <div class="flight-stat-group">
                <span class="flight-stat-icon">⏱</span>
                <span id="flight-timer" class="flight-stat-value">60</span>
            </div>
        </div>

        <!-- Правый нижний — подсказки управления -->
        <div class="flight-hints">
            <div class="flight-hint-row"><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> <span>Маневрирование</span></div>
            <div class="flight-hint-row"><kbd>Space</kbd> <span>Ускорение</span></div>
        </div>
    </div>

    <!-- Оверлей результатов (Стейт 3) -->
    <div id="flight-results" class="flight-results-overlay hidden">
        <div class="game-card" style="max-width:420px;text-align:center;padding:2rem;">
            <h2 class="game-title" style="font-size:1.5rem;margin-bottom:1rem;">Полёт завершён!</h2>
            <div id="flight-results-stats" style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:1.5rem;"></div>
            <div style="display:flex;gap:1rem;justify-content:center;">
                <button class="btn-game btn-primary" onclick="window._flightScreen?.restart()">🔄 Ещё раз</button>
                <button class="btn-game btn-secondary" onclick="window._spa?.goto('galaxy-map')">🌌 К карте</button>
            </div>
        </div>
    </div>
</div>
