<!-- _ScreenGalaxyMap.cshtml — Звёздная карта с 3D-визуализацией -->
<div class="screen" id="screen-galaxy-map"
     style="width:100%;height:100%;display:grid;grid-template-rows:auto 1fr auto;overflow:hidden;">

    <!-- ═══ Шапка ═══ -->
    <header class="galaxy-header">
        <h1 class="game-title" style="font-size:1.15rem;">🌌 Карта Галактики</h1>

        <!-- Tabs: 3D ↔ Список -->
        <div class="galaxy-tabs">
            <button id="tab-3d" class="galaxy-tab galaxy-tab--active" onclick="window._galaxyMap?.setView('3d')">
                <span class="nav-icon">🪐</span> 3D-вид
            </button>
            <button id="tab-list" class="galaxy-tab" onclick="window._galaxyMap?.setView('list')">
                <span class="nav-icon">📋</span> Список
            </button>
        </div>

        <!-- Фильтры -->
        <div class="galaxy-filters">
            <select id="filter-category" onchange="window._galaxyMap?.applyFilter()"
                    class="galaxy-select">
                <option value="">Все направления</option>
                <option value="technology">💻 Технологии</option>
                <option value="medicine">⚕ Медицина</option>
                <option value="biotech">🧬 Биотех</option>
                <option value="ecology">🌿 Экология</option>
                <option value="design">🎨 Дизайн</option>
                <option value="neuroscience">🧠 Нейронауки</option>
                <option value="physics">⚛ Физика</option>
                <option value="mathematics">📐 Математика</option>
            </select>
            <select id="filter-status" onchange="window._galaxyMap?.applyFilter()"
                    class="galaxy-select">
                <option value="">Все планеты</option>
                <option value="discovered">Открытые</option>
                <option value="hidden">Не открытые</option>
            </select>
        </div>

        <!-- Кнопки -->
        <div class="galaxy-actions">
            <button class="btn-game btn-primary" onclick="window._galaxyMap?.openScan()" style="padding:6px 14px;font-size:0.78rem;">
                🔭 Сканировать
            </button>
            <button class="btn-game btn-secondary" onclick="window._spa?.goto('flight')" style="padding:6px 14px;font-size:0.78rem;">
                🚀 Полёт
            </button>
        </div>
    </header>

    <!-- ═══ Контент: 3D Вид ═══ -->
    <div id="galaxy-3d-container" class="galaxy-content-panel" style="position:relative;">
        <!-- 3D-звёздная карта рендерится сюда через JS -->
        <div id="galaxy-3d-canvas-wrap" style="width:100%;height:100%;position:relative;">
            <!-- Тултип при наведении на планету -->
            <div id="galaxy-tooltip" class="galaxy-tooltip hidden">
                <div id="galaxy-tooltip-name" class="galaxy-tooltip-name"></div>
                <div id="galaxy-tooltip-cat" class="galaxy-tooltip-cat"></div>
                <div id="galaxy-tooltip-hint" class="galaxy-tooltip-hint">Клик — открыть</div>
            </div>
        </div>
    </div>

    <!-- ═══ Контент: Список ═══ -->
    <div id="galaxy-list-container" class="galaxy-content-panel hidden">
        <div id="planet-grid"
             style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;padding:0.75rem;overflow-y:auto;max-height:100%;">
            <div style="grid-column:1/-1;text-align:center;color:var(--color-text-muted);padding:3rem;">
                <div style="font-size:2rem;margin-bottom:0.5rem;">🌌</div>
                <p>Загрузка карты галактики…</p>
            </div>
        </div>
    </div>

    <!-- ═══ Подвал ═══ -->
    <footer class="galaxy-footer">
        <span id="stat-discovered" class="galaxy-stat">📍 Открыто: 0</span>
        <span id="stat-total" class="galaxy-stat">🌐 Всего: 0</span>
        <div class="galaxy-footer-actions">
            <button class="btn-game btn-secondary" onclick="window._spa?.goto('achievements')" style="padding:4px 12px;font-size:0.72rem;">
                📊 Прогресс
            </button>
            <button class="btn-game btn-secondary" onclick="window._spa?.goto('vocation-constellation')" style="padding:4px 12px;font-size:0.72rem;">
                🌠 Созвездие
            </button>
        </div>
    </footer>
</div>
