<!-- _ScreenGalaxyMap.cshtml — Звёздная карта галактики -->
<div class="screen" id="screen-galaxy-map"
     style="width:100%;min-height:100vh;display:grid;grid-template-rows:auto 1fr auto;padding:1rem;gap:1rem;">

    <!-- Шапка -->
    <header style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <h1 class="game-title" style="font-size:1.2rem;">🌌 Карта Галактики</h1>

        <!-- Фильтры -->
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            <select id="filter-category" onchange="window._galaxyMap?.applyFilter()"
                    style="background:rgba(15,23,42,0.8);border:1px solid var(--color-border);color:var(--color-text);border-radius:var(--radius-sm);padding:6px 10px;font-size:0.8rem;">
                <option value="">Все направления</option>
                <option value="technology">Технологии</option>
                <option value="medicine">Медицина</option>
                <option value="biotech">Биотех</option>
                <option value="ecology">Экология</option>
                <option value="design">Дизайн</option>
                <option value="neuroscience">Нейронауки</option>
            </select>
            <select id="filter-status" onchange="window._galaxyMap?.applyFilter()"
                    style="background:rgba(15,23,42,0.8);border:1px solid var(--color-border);color:var(--color-text);border-radius:var(--radius-sm);padding:6px 10px;font-size:0.8rem;">
                <option value="">Все планеты</option>
                <option value="discovered">Открытые</option>
                <option value="hidden">Не открытые</option>
            </select>
        </div>

        <!-- Кнопки -->
        <div style="display:flex;gap:0.5rem;">
            <button class="btn-game btn-primary" onclick="window._galaxyMap?.openScan()" style="padding:6px 16px;font-size:0.8rem;">
                🔭 Сканировать туманность
            </button>
            <button class="btn-game btn-secondary" onclick="window._spa?.pause()" style="padding:6px 12px;font-size:0.8rem;">⏸</button>
        </div>
    </header>

    <!-- Сетка планет -->
    <div id="planet-grid"
         style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;overflow-y:auto;padding:0.5rem;">
        <!-- Карточки планет рендерятся через JS -->
        <div style="grid-column:1/-1;text-align:center;color:var(--color-text-muted);padding:3rem;">
            <div style="font-size:2rem;margin-bottom:0.5rem;">🌌</div>
            <p>Загрузка карты галактики…</p>
        </div>
    </div>

    <!-- Подвал с прогрессом -->
    <footer style="display:flex;flex-wrap:wrap;gap:1rem;padding:0.5rem;background:rgba(5,10,26,0.6);border-radius:var(--radius-sm);">
        <span id="stat-discovered" style="color:var(--color-text-muted);font-size:0.8rem;">📍 Открыто: 0</span>
        <span id="stat-total"      style="color:var(--color-text-muted);font-size:0.8rem;">🌐 Всего: 0</span>
        <button class="btn-game btn-secondary" onclick="window._spa?.goto('achievements')" style="padding:4px 12px;font-size:0.75rem;margin-left:auto;">
            📊 Прогресс
        </button>
        <button class="btn-game btn-secondary" onclick="window._spa?.goto('vocation-constellation')" style="padding:4px 12px;font-size:0.75rem;">
            🌠 Созвездие
        </button>
    </footer>
</div>
