@page
@model KosmosCore.Pages.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

@section Head {
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-card__icon">✨</div>
        <h1 class="auth-card__title">Регистрация</h1>
        <p class="auth-card__subtitle">Создайте аккаунт для доступа к системе</p>

        <div asp-validation-summary="ModelOnly"></div>

        <form method="post">
            <div class="auth-field">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" placeholder="Придумайте логин" autocomplete="username" />
                <span asp-validation-for="UserName"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" placeholder="Придумайте пароль" autocomplete="new-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <div class="auth-field">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" placeholder="Повторите пароль" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword"></span>
            </div>

            <button type="submit" class="auth-btn">Зарегистрироваться</button>
        </form>

        <div class="auth-footer">
            Уже есть аккаунт? <a asp-page="/Login">Войти</a>
        </div>
    </div>
</div>
