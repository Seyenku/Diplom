@namespace KosmosCore.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var pagePath = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isGamePage = pagePath.Equals("/Game", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KosmosCore</title>
    
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net http://localhost:* https://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://cdn.jsdelivr.net http://localhost:* https://localhost:* ws://localhost:* wss://localhost:*;" />
    <script>
        (() => {
            const savedTheme = localStorage.getItem('kosmos-theme');
            const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
            document.documentElement.dataset.theme = savedTheme || (prefersDark ? 'dark' : 'light');
        })();
    </script>
    
    <link rel="stylesheet" href="~/css/StyleSheet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KosmosCore.styles.css" asp-append-version="true" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100..900&display=swap" rel="stylesheet" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@(isGamePage ? "game-layout" : "standard-layout")">
    <header class="site-header">
        <partial name="_NavPartial" />
    </header>

    <main role="main" class="container site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-block">
                <img src="~/images/anoamusrk.png" alt="anoamusrk" class="footer-logo" />
                <small class="footer-text">Copyright © Автономная некоммерческая организация "Ассоциация молодых ученых и специалистов Республики Коми" совместно с ФГБОУ ВО "СГУ имени Питирима Сорокина"</small>
            </div>
            <div class="footer-block">
                <img src="~/images/itnit.png" alt="itnit" class="footer-logo" />
                <small class="footer-text">Портал разрабатывается и тестируется на базе института точных наук и информационных технологий СГУ им. Питирима Сорокина</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>
    <!-- stats.js removed to prevent 404 error -->
    <script>
        (() => {
            const buttons = document.querySelectorAll('[data-theme-toggle]');
            if (!buttons.length) return;

            const startThemeTransition = button => {
                const root = document.documentElement;
                const bodyStyles = getComputedStyle(document.body);
                const overlay = document.createElement('div');

                overlay.className = 'theme-fade-overlay';
                overlay.style.backgroundColor = bodyStyles.backgroundColor;
                overlay.style.backgroundImage = bodyStyles.backgroundImage;
                document.body.appendChild(overlay);

                root.classList.remove('theme-transitioning');
                button.classList.remove('theme-toggle--changing');
                void root.offsetWidth;
                root.classList.add('theme-transitioning');
                button.classList.add('theme-toggle--changing');

                requestAnimationFrame(() => overlay.classList.add('theme-fade-overlay--hide'));
                window.setTimeout(() => {
                    overlay.remove();
                    root.classList.remove('theme-transitioning');
                    button.classList.remove('theme-toggle--changing');
                }, 520);
            };

            const applyTheme = theme => {
                document.documentElement.dataset.theme = theme;
                localStorage.setItem('kosmos-theme', theme);
                buttons.forEach(button => {
                    button.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
                    const label = theme === 'dark' ? 'Светлая тема' : 'Темная тема';
                    button.setAttribute('aria-label', label);
                    button.title = label;
                });
                window.dispatchEvent(new CustomEvent('kosmos:themechange', { detail: { theme } }));
            };

            applyTheme(document.documentElement.dataset.theme || 'light');
            buttons.forEach(button => {
                button.addEventListener('click', () => {
                    startThemeTransition(button);
                    applyTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
                });
            });
        })();
    </script>
    <script>
        (() => {
            if (!document.body.classList.contains('standard-layout')) return;

            const revealSelector = [
                '.hero-content',
                '.proekt-heading',
                '.about-card',
                '.card-item',
                '.spec-header',
                '.spec-toolbar',
                '.spec-result-panel',
                '.spec-card',
                '.spec-empty',
                '.test-hero',
                '.test-side__panel',
                '.test-card',
                '.auth-card'
            ].join(',');

            const items = [...document.querySelectorAll(revealSelector)]
                .filter(item => !item.closest('.game-page-container'));

            items.forEach((item, index) => {
                item.setAttribute('data-reveal', '');
                item.style.setProperty('--reveal-delay', `${Math.min(index * 45, 360)}ms`);
            });

            if (!('IntersectionObserver' in window)) {
                items.forEach(item => item.classList.add('is-visible'));
                return;
            }

            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                });
            }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });

            requestAnimationFrame(() => items.forEach(item => observer.observe(item)));
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
