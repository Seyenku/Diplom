@namespace KosmosCore.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KosmosCore</title>
    
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net http://localhost:* https://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://cdn.jsdelivr.net http://localhost:* https://localhost:* ws://localhost:* wss://localhost:*;" />
    
    <link rel="stylesheet" href="~/css/StyleSheet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KosmosCore.styles.css" asp-append-version="true" />
    <script src="~/js/particles.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <header>
        <div class="header">
            <div id="particles-js" style="height: 10vh;" class="header_dd gradient">
                <partial name="_NavPartial" />
            </div>
        </div>
    </header>

    <main role="main" class="container" style="padding: 0;">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-block">
                <img src="~/images/anoamusrk.png" alt="anoamusrk" class="footer-logo" />
                <small class="footer-text">Copyright © Автономная некоммерческая организация "Ассоциация молодых ученых и специалистов Республики Коми" совместно с ФГБОУ ВО "СГУ имени Питирима Сорокина"</small>
            </div>
            <div class="footer-block">
                <img src="~/images/itnit.png" alt="itnit" class="footer-logo" />
                <small class="footer-text">Портал разрабатывается и тестируется на базе института точных наук и информационных технологий СГУ им. Питирима Сорокина</small>
            </div>
        </div>
    </footer>

    <script src="~/js/app.js" asp-append-version="true"></script>
    <!-- stats.js removed to prevent 404 error -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
