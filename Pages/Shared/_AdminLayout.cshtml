@namespace KosmosCore.Pages.Admin
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    string Active(string target) => page.Equals(target, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KosmosCore</title>
    <script>
        (() => {
            const savedTheme = localStorage.getItem('kosmos-theme');
            const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
            document.documentElement.dataset.theme = savedTheme || (prefersDark ? 'dark' : 'light');
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100..900&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/StyleSheet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <aside class="admin-sidebar clay-surface">
            <div class="admin-sidebar-header">
                <div class="admin-brand-mark">KC</div>
                <div>
                    <h2>KosmosCore</h2>
                    <span>Личный кабинет</span>
                </div>
            </div>

            <nav class="admin-nav" aria-label="Админ-навигация">
                <ul>
                    <li><a asp-page="/Admin/Index" class="@Active("/Admin/Index")">Главная</a></li>
                    <li><a asp-page="/Admin/Directions" class="@Active("/Admin/Directions")">Направления</a></li>
                    @if (isSuperAdmin)
                    {
                        <li><a asp-page="/Admin/Planets" class="@Active("/Admin/Planets")">Планеты</a></li>
                        <li><a asp-page="/Admin/Users" class="@Active("/Admin/Users")">Администраторы</a></li>
                    }
                    <li><a asp-page="/Admin/GraphicView" class="@Active("/Admin/GraphicView")">Аналитика</a></li>
                    <li><a asp-page="/Index">Перейти на сайт</a></li>
                </ul>
            </nav>

            <div class="admin-sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="admin-sidebar-user">
                        <span>@(isSuperAdmin ? "Суперадмин" : "Админ")</span>
                        <b>@User.Identity.Name</b>
                    </div>
                    <form method="post" asp-page="/Logout">
                        <button type="submit" class="admin-btn-logout">Выйти</button>
                    </form>
                }
            </div>
        </aside>

        <main class="admin-main">
            <header class="admin-topbar">
                <div>
                    <span class="admin-topbar__label">KosmosCore</span>
                    <h1 class="admin-page-title">@ViewData["Title"]</h1>
                </div>
                <button class="theme-toggle theme-toggle--admin" type="button" data-theme-toggle aria-label="Темная тема" title="Темная тема">
                    <span class="theme-toggle__sun" aria-hidden="true">☀</span>
                    <span class="theme-toggle__moon" aria-hidden="true">☾</span>
                </button>
            </header>

            <div class="admin-content-inner">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        (() => {
            const buttons = document.querySelectorAll('[data-theme-toggle]');
            if (!buttons.length) return;

            const startThemeTransition = button => {
                const root = document.documentElement;
                const bodyStyles = getComputedStyle(document.body);
                const overlay = document.createElement('div');

                overlay.className = 'theme-fade-overlay';
                overlay.style.backgroundColor = bodyStyles.backgroundColor;
                overlay.style.backgroundImage = bodyStyles.backgroundImage;
                document.body.appendChild(overlay);

                root.classList.remove('theme-transitioning');
                button.classList.remove('theme-toggle--changing');
                void root.offsetWidth;
                root.classList.add('theme-transitioning');
                button.classList.add('theme-toggle--changing');

                requestAnimationFrame(() => overlay.classList.add('theme-fade-overlay--hide'));
                window.setTimeout(() => {
                    overlay.remove();
                    root.classList.remove('theme-transitioning');
                    button.classList.remove('theme-toggle--changing');
                }, 520);
            };

            const applyTheme = theme => {
                document.documentElement.dataset.theme = theme;
                localStorage.setItem('kosmos-theme', theme);
                buttons.forEach(button => {
                    button.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
                    const label = theme === 'dark' ? 'Светлая тема' : 'Темная тема';
                    button.setAttribute('aria-label', label);
                    button.title = label;
                });
                window.dispatchEvent(new CustomEvent('kosmos:themechange', { detail: { theme } }));
            };

            applyTheme(document.documentElement.dataset.theme || 'light');
            buttons.forEach(button => {
                button.addEventListener('click', () => {
                    startThemeTransition(button);
                    applyTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
                });
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
