@{
    var isActive = new Func<string, string>(page =>
        ViewContext.RouteData.Values["page"]?.ToString()
            ?.Equals(page, StringComparison.OrdinalIgnoreCase) == true ? "active" : "");
}

<nav class="site-nav">
    <a href="~/" class="site-nav__brand">KosmosCore</a>

    <ul class="site-nav__links">
        <li><a href="~/" class="@isActive("/Index")">Главная</a></li>
        <li><a href="~/test" class="@isActive("/Test")">Тест</a></li>
        <li><a href="~/spec" class="@isActive("/Spec")">Направления</a></li>
        <li><a href="~/game" class="@isActive("/Game")">Атлас</a></li>
    </ul>

    <div class="site-nav__actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="site-nav__username">@User.Identity.Name</span>
            <form method="post" asp-page="/Logout" style="display:inline;">
                <button type="submit" class="site-nav__btn site-nav__btn--ghost">Выйти</button>
            </form>
        }
        else
        {
            <a href="~/login" class="site-nav__btn site-nav__btn--ghost">Войти</a>
        }

        @if (User.IsInRole("admin"))
        {
            <a href="~/admin" class="site-nav__btn site-nav__btn--accent">Личный кабинет</a>
        }
    </div>
</nav>