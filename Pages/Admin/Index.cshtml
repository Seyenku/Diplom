@page
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@{
    ViewData["Title"] = "Админ-панель";
    Layout = "_AdminLayout";
}

<div class="admin-card">
    <h2 class="admin-card-title">Добро пожаловать</h2>
    <p style="color: var(--color-text-muted);">Вы находитесь в панели управления проектом KosmosCore. Выберите нужный раздел в левом меню.</p>
</div>

<div class="admin-actions-grid">
    <div class="admin-card">
        <h3 class="admin-card-title">Статистика системы</h3>
        <ul class="admin-stats-list">
            <li><strong>Всего профессий:</strong> <span>--</span></li>
            <li><strong>Активных пользователей:</strong> <span>--</span></li>
            <li><strong>Пройдено тестов:</strong> <span>--</span></li>
        </ul>
    </div>
    <div class="admin-card">
        <h3 class="admin-card-title">Быстрые действия</h3>
        <div class="admin-actions-col">
            <button class="site-nav__btn site-nav__btn--accent" style="width: 100%;">Добавить профессию</button>
            <button class="site-nav__btn site-nav__btn--ghost" style="width: 100%;">Посмотреть логи</button>
        </div>
    </div>
</div>
