@page
@model ErrorModel
@{
    ViewData["Title"] = "Произошла ошибка";
}

<div class="test-wizard-container error-page-container">
    <div class="wizard-card">
        <div class="error-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1a.05.05 0 0 1 .1-.1h.8a.05.05 0 0 1 .1.1v4.7a.05.05 0 0 1-.1.1h-.8a.05.05 0 0 1-.1-.1V7.1z"/>
            </svg>
        </div>

        <h1 class="error-title">
            Упс! Что-то пошло не так
        </h1>
        
        <p class="error-text">
            Мы уже в курсе проблемы и работаем над её решением. Пожалуйста, попробуйте обновить страницу позже.
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="error-request-id">
                <span class="error-request-label">ID запроса:</span>
                <code class="error-request-code">@Model.RequestId</code>
            </div>
        }
        <br/>
        <a href="/" class="site-nav__btn site-nav__btn--accent error-home-link">Вернуться на главную</a>

        @* Блок для разработчиков *@
        <div class="dev-alert">
            <h4 class="dev-alert__title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-exclamation-triangle-fill dev-alert__icon" viewBox="0 0 16 16">
                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
                Режим разработки
            </h4>
            <p class="dev-alert__text">
                Подробная информация об ошибке доступна только в среде <strong>Development</strong>.
                В продакшене этот блок должен быть скрыт, чтобы избежать утечки конфиденциальных данных.
            </p>
            <p class="dev-alert__note">
                Совет: Установите переменную <code>ASPNETCORE_ENVIRONMENT</code> в значение <code>Development</code> для локальной отладки.
            </p>
        </div>
    </div>
</div>
