## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build logs
*.log

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.res
*.sbr
*.idb
*.pdb
*.obj
*.pch
*.res
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.zip
*.rgs
*.exp
*.lib
*.map
*.swp
*.lock
.aspnetconfig.module
node_modules/
wwwroot/js/game/*.js.map
wwwroot/js/game/*.js
!wwwroot/js/game/three*.js
!wwwroot/js/game/particles.js
!wwwroot/js/game/app.js
wwwroot/js/game/screens/*.js
Properties/launchSettings.json

# Tool-specific files
.sonarlint/
.sonar/
*.sln.DotSettings.user

# Mac files
.DS_Store

# User-specific project settings
*.csproj.user
*.sqlproj.user
*.pubxml.user

# Entity Framework Core migrations
# Uncomment if you don't want to track migrations
# [Mm]igrations/

# Secrets and configuration
appsettings.json
appsettings.Development.json
secrets.json
.env
